# Required: Anthropic API key. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: model id. Default is claude-sonnet-4-5-20250929.
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Required: Postgres connection string.
# Use Neon (https://neon.tech free tier), Supabase, or Vercel Postgres.
# Format: postgres://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=postgres://user:password@host:5432/hyperagent?sslmode=require

# Required for the cron route (any random string — used to gate /api/cron)
CRON_SECRET=change-me-in-prod

# Required: Composio API key. Get one at https://app.composio.dev
# Composio handles OAuth + execution for 500+ third-party integrations
# (Slack, Gmail, Linear, GitHub, Notion, Airtable, etc.)
COMPOSIO_API_KEY=ak_...

# Required for browser automation + computer use tools.
# Sign up at https://hyperbrowser.ai (free tier).
HYPERBROWSER_API_KEY=hb_...

# Required for at least one media provider. Configure any/all:
# Gemini (Nano Banana image, TTS, Veo video) — https://aistudio.google.com (free)
GEMINI_API_KEY=AI...
# OpenAI (gpt-image-1 image, tts-1 speech, Sora video) — https://platform.openai.com
OPENAI_API_KEY=sk-...
# xAI Grok (grok-2-image only — no TTS/video yet) — https://console.x.ai
XAI_API_KEY=xai-...

# Stripe — for real billing. Without these, /api/credits/topup falls back to dev-credit mode.
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Slack inbound (P15). Set after creating a Slack app at api.slack.com.
# SLACK_SIGNING_SECRET is used to verify webhook signatures.
SLACK_SIGNING_SECRET=...
