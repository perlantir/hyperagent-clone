# Required: Anthropic API key. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: model id. Default is claude-sonnet-4-5-20250929.
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Required: Postgres connection string.
# Use Neon (https://neon.tech free tier), Supabase, or Vercel Postgres.
# Format: postgres://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=postgres://user:password@host:5432/hyperagent?sslmode=require

# Required for the cron route (any random string — used to gate /api/cron)
CRON_SECRET=change-me-in-prod
