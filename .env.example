# =============================================================================
#  Required platform vars
# =============================================================================

# Postgres connection string. Use Neon (free tier), Supabase, or Vercel Postgres.
DATABASE_URL=postgres://user:password@host:5432/hyperagent?sslmode=require

# Any random string — gates /api/cron from being called by the public.
CRON_SECRET=change-me-in-prod

# Strongly recommended for production. Encrypts user-saved API keys at rest
# (AES-256-GCM). If unset, falls back to a key derived from DATABASE_URL —
# fine for dev, but anyone with DB access could decrypt. Set once and don't
# rotate without re-encrypting existing rows. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=base64-32-bytes-here

# =============================================================================
#  Provider keys — PLATFORM-WIDE FALLBACKS ONLY
# =============================================================================
# Each user can set their own key in Settings → API Keys (encrypted in DB).
# Setting these env vars makes Hyperagent work for new users out of the box;
# they can override with their own key later. Leave blank to require BYO keys.

# Default chat model (any user with no Anthropic key uses this)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Multi-provider chat + media. Optional but enables OpenAI/Gemini/Grok models.
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...
XAI_API_KEY=xai-...

# Browser/computer-use tools (Hyperbrowser cloud Chromium)
HYPERBROWSER_API_KEY=hb_...

# Composio — 500+ third-party connectors (Slack, Gmail, GitHub, Notion…)
COMPOSIO_API_KEY=ak_...

# e2b — sandboxed code execution (Python, shell)
E2B_API_KEY=e2b_...

# =============================================================================
#  Platform-only secrets (NOT user-scoped)
# =============================================================================

# Stripe billing. Without these, /api/credits/topup falls back to dev-credit mode.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Slack inbound webhook signature verification.
# Set after creating a Slack app at api.slack.com.
SLACK_SIGNING_SECRET=...

# Liveblocks — real-time presence + collaboration on threads.
# Sign up at liveblocks.io, create a project, copy both keys.
LIVEBLOCKS_SECRET_KEY=sk_prod_...
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=pk_prod_...
